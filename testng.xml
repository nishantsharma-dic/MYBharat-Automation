<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Default TestNG suite – runs the smoke tests.
  Use testSuites/testng-suite_Youth.xml for the full Youth regression suite.

  Override browser and environment at runtime:
    mvn test -Dbrowser=chrome -Denv=qa
-->
<suite name="MYBharat Smoke Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="MYBharat.Test.TestComponents.Listeners"/>
    </listeners>

    <test name="Youth Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="MYBharat.Test.tests.youth.YouthTest"/>
        </classes>
    </test>

</suite>
