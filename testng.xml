<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Default suite - runs Registration + Profile sequentially on same browser.
  
  Run: mvn test -Denv=prod -Dbrowser=firefox
  
  For all modules: mvn test -Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml
-->
<suite name="MYBharat Smoke Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.YouthRegistrationTest"/>
        </classes>
    </test>

    <test name="Registration Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
        </classes>
    </test>

    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
