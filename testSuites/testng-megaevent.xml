<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Mega Event Creation Flow
  
  Run:
    mvn test -Denv=prod -Dbrowser=chrome "-Dsurefire.suiteXmlFiles=testSuites/testng-megaevent.xml"
-->
<suite name="Mega Event Module" parallel="none" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Create Mega Event">
        <classes>
            <class name="com.mybharat.tests.megaevent.MegaEventTest"/>
        </classes>
    </test>

</suite>
