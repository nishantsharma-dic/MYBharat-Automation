<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Youth full regression suite.
  Run with: mvn test -Dsurefire.suiteXmlFiles=testSuites/testng-suite_Youth.xml
-->
<suite name="Youth Regression Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="MYBharat.Test.TestComponents.Listeners"/>
    </listeners>

    <test name="Youth Registration and Quiz Tests">
        <classes>
            <class name="MYBharat.Test.tests.youth.YouthTest">
                <methods>
                    <include name="signUpNationalUser"/>
                    <!-- Uncomment to include additional tests:
                    <include name="signUpInternationalUser"/>
                    <include name="fillYouthPublicProfile"/>
                    <include name="playQuiz"/>
                    -->
                </methods>
            </class>
        </classes>
    </test>

</suite>
