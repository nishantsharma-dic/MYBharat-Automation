<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Organisation Creation regression suite.
  Add the GenericOrgCreationTest class once it is implemented.
  Run with: mvn test -Dsurefire.suiteXmlFiles=testSuites/testng-suite_OrgCreation.xml
-->
<suite name="OrgCreation Regression Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="MYBharat.Test.TestComponents.Listeners"/>
    </listeners>

    <test name="Organisation Creation Tests">
        <classes>
            <class name="MYBharat.Test.tests.youth.YouthTest">
                <methods>
                    <include name="signUpNationalUser"/>
                </methods>
            </class>
            <!--
            Uncomment when GenericOrgCreationTest is implemented:
            <class name="MYBharat.Test.tests.Nodal.GenericOrgCreationTest">
                <methods>
                    <include name="genericOrganisationCreation"/>
                </methods>
            </class>
            -->
        </classes>
    </test>

</suite>
