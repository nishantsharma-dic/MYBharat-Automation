<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  VO Youth Side - Login → Search Event → Upload Images → Apply

  Run:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-vo-youth.xml
-->
<suite name="VO Youth Cycle" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="VO Youth Flow" preserve-order="true">
        <classes>
            <class name="com.mybharat.tests.vo.VOYouthLoginTest"/>
            <class name="com.mybharat.tests.vo.YouthApplyOnVOTest"/>
        </classes>
    </test>

</suite>
