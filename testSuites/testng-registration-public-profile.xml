<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
  Registration + Public Profile Suite
  ============================================================
  Purpose: End-to-end youth journey starting from registration to profile completion
           with public profile verification.
  
  Important: Both tests are in the SAME <test> block, so they share the SAME browser session.
             - RegistrationTest: Registers new user, saves email to Excel
             - YouthProfileTest: Navigates to profile page, fills all sections including public profile verification
  
  Flow:
    Step 1: Youth Registration — Register new Indian youth, save email to Excel
    Step 2: Youth Profile Completion — Complete all sections including public profile verification
  
  Prerequisites:
    - Yopmail must be accessible (for OTP in registration)
    - resources/ folder must be writable (Excel persistence)
    - UploadImages/ folder must contain test images (for profile photo upload)
  
  Run with:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-registration-public-profile.xml
    mvn test -Denv=beta -Dbrowser=headless -DciMode=true -Dsurefire.suiteXmlFiles=testSuites/testng-registration-public-profile.xml
  
  Team: QA Team | Developer: Nishant Sharma
  ============================================================
-->
<suite name="Registration + Public Profile" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Single test block: Both tests share the same browser session -->
    <test name="Registration + Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

</suite>
