<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Blog Module Test Suite
  
  Flow: Login (last email from Youth_beta/Youth_prod) → Submit popup → Navigate to Blogs → Write Blog
  
  All steps run on the SAME browser session (single <test> block).
  
  Run with:
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-blog.xml -DcloseBrowser=false
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-blog.xml -DcloseBrowser=false
-->
<suite name="Blog Module Suite" parallel="none" verbose="1" preserve-order="true">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Blog Flow" preserve-order="true">
        <classes>
            <!-- Step 1: Login with last email from Youth_beta/Youth_prod Excel -->
            <class name="com.mybharat.tests.youth.LoginTest"/>
            <!-- Step 2: Blog Creation (submit popup + navigate to blogs + write) -->
            <class name="com.mybharat.tests.blog.BlogTest"/>
        </classes>
    </test>

</suite>
