<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Registration + Login + Profile + Certificate only.
  
  Run with:
    mvn test -Denv=prod -Dbrowser=firefox -Dsurefire.suiteXmlFiles=testSuites/testng-profile-certificate.xml -DcloseBrowser=false
-->
<suite name="Profile and Certificate Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.YouthRegistrationTest"/>
        </classes>
    </test>

    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <test name="Registration Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
        </classes>
    </test>

</suite>
