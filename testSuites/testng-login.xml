<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Login ONLY (requires registration to have run first — email saved in Excel)
  
  Run:
    mvn test -Denv=prod -Dbrowser=chrome "-Dsurefire.suiteXmlFiles=testSuites/testng-login.xml"
-->
<suite name="Login Module" parallel="none" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

</suite>
