<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
  Login Module Suite
  ============================================================
  Purpose: Tests the OTP-based login flow for a previously registered user.
  
  Prerequisites:
    - Registration must have been run at least once on the target environment
    - Youth_{env}.xlsx must contain at least one email entry
    - Yopmail must be accessible for OTP retrieval
  
  Flow:
    1. Navigate to MYBharat home page
    2. Click "Sign In"
    3. Enter email (read from Youth_beta.xlsx or Youth_prod.xlsx)
    4. Send OTP → Fetch from Yopmail → Verify OTP
    5. Assert login success
  
  Run with:
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-login.xml
    mvn test -Denv=prod -Dbrowser=firefox -Dsurefire.suiteXmlFiles=testSuites/testng-login.xml
  
  Team: QA Team | Developer: Nishant Sharma
  ============================================================
-->
<suite name="Login Module" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

</suite>
