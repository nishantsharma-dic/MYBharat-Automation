<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Mega Event Full Flow: Upload Photos + Create Mega Event (Single Browser Session)
  
  Flow:
    1. Login (Youth user) → Upload Photos to existing Mega Event (Past tab)
    2. Logout
    3. Login (Partner user) → Create new Mega Event

  Single <test> block = single browser session (no browser close between flows).
  preserve-order ensures Photo Upload runs completely before Create Mega Event.

  Run:
    mvn test -Denv=prod -Dbrowser=chrome "-Dsurefire.suiteXmlFiles=testSuites/testng-megaevent-full.xml"
-->
<suite name="Mega Event Full Flow" parallel="none" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Mega Event Upload + Create" preserve-order="true">
        <classes>
            <class name="com.mybharat.tests.megaevent.MegaEventPhotoUploadTest"/>
            <class name="com.mybharat.tests.megaevent.MegaEventTest"/>
        </classes>
    </test>

</suite>
