<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ╔══════════════════════════════════════════════════════════════════════╗
  ║              REGISTRATION + QUIZ - STANDALONE SUITE                  ║
  ╠══════════════════════════════════════════════════════════════════════╣
  ║                                                                     ║
  ║  Purpose: Register a new user and immediately play quiz             ║
  ║  No prerequisites needed (creates fresh user each run)              ║
  ║                                                                     ║
  ║  Flow:                                                              ║
  ║    1. Register new Indian youth (random email via Yopmail)          ║
  ║    2. Submit popup → User is on quiz page                           ║
  ║    3. Play competitive quiz (dynamic question count)                ║
  ║    4. Submit quiz + provide feedback                                ║
  ║                                                                     ║
  ║  Note: User stays logged in after registration (no logout/login)    ║
  ║  Note: Email saved to Youth_beta/Youth_prod.xlsx for future use     ║
  ║                                                                     ║
  ║  Run:                                                               ║
  ║    mvn test -Denv=prod -Dbrowser=chrome                             ║
  ║      -Dsurefire.suiteXmlFiles=testSuites/testng-registration-quiz.xml║
  ║      -DcloseBrowser=false                                           ║
  ║                                                                     ║
  ║    mvn test -Denv=beta -Dbrowser=chrome                             ║
  ║      -Dsurefire.suiteXmlFiles=testSuites/testng-registration-quiz.xml║
  ║      -DcloseBrowser=false                                           ║
  ║                                                                     ║
  ╚══════════════════════════════════════════════════════════════════════╝
-->
<suite name="Registration + Quiz" parallel="none" verbose="1" preserve-order="true">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Register and Play Quiz" preserve-order="true">
        <classes>
            <!-- Register new youth user (email + OTP from Yopmail, saves to Excel) -->
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
            <!-- Play quiz immediately after registration (user already logged in) -->
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
