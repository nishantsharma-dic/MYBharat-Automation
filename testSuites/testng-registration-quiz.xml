<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  Registration + Quiz Suite (same browser session)
  
  Flow: Register new user → Play Quiz
  
  Run with:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-registration-quiz.xml -DcloseBrowser=false
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-registration-quiz.xml -DcloseBrowser=false
-->
<suite name="Registration + Quiz" parallel="none" verbose="1" preserve-order="true">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Register and Play Quiz" preserve-order="true">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
