<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  VO (Volunteer for Bharat) Partner Side - Single browser session

  Flow:
    Step 1: Login as VO Partner user
    Step 2: Navigate to Templates → Create Template
    Step 3: Navigate to Events → Add Event → Preview → Publish

  Run:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-vo.xml
-->
<suite name="VO Test Cycle" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="VO Partner Cycle" preserve-order="true">
        <classes>
            <class name="com.mybharat.tests.vo.VOLoginTest"/>
            <class name="com.mybharat.tests.vo.VOTemplateNodalDyoTest"/>
            <class name="com.mybharat.tests.vo.VOCreateTest"/>
            <class name="com.mybharat.tests.vo.VOEventNavigationTest"/>
            <class name="com.mybharat.tests.vo.VOEventCreateTest"/>
        </classes>
    </test>

</suite>
