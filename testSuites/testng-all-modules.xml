<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ALL MODULES - Runs all modules SEQUENTIALLY on the SAME browser.
  
  Flow: Registration → Logout → Login → Profile → Certificate → Basic Info → Quiz
  
  Run with:
    mvn test -Denv=beta -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml
    mvn test -Denv=prod -Dbrowser=firefox -Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml
  
  Execution order:
    1. Youth Registration
    2. Youth Login
    3. Youth Profile Completion
    4. Registration Certificate Verification
    5. Youth Basic Info
    6. Quiz Attempt
    7. CV Builder (TODO)
    8. Organisation Creation (TODO)
    9. Join Organisation (TODO)
-->
<suite name="MYBharat All Modules" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Registration → Submit popup → Save email to Excel -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
        </classes>
    </test>

    <!-- Step 2: Logout after registration -->
    <test name="Logout After Registration">
        <classes>
            <class name="com.mybharat.tests.youth.LogoutTest"/>
        </classes>
    </test>

    <!-- Step 3: Login with email from Excel (password: 25@March) -->
    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

    <!-- Step 3: Complete Youth Profile -->
    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <!-- Step 4: Registration Certificate Verification -->
    <test name="Registration Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
        </classes>
    </test>

    <!-- Step 5: Basic Info + Extract Email -->
    <test name="Youth Basic Info">
        <classes>
            <class name="com.mybharat.tests.youth.BasicInfoTest"/>
        </classes>
    </test>

    <!-- Step 6: Quiz Attempt -->
    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

    <!-- Module 7: CV Builder (TODO) -->
    <!--
    <test name="CV Builder">
        <classes>
            <class name="com.mybharat.tests.cvbuilder.CVBuilderTest"/>
        </classes>
    </test>
    -->

    <!-- Module 8: Organisation Creation (TODO) -->
    <!--
    <test name="Organisation Creation">
        <classes>
            <class name="com.mybharat.tests.organisation.OrgCreationTest"/>
        </classes>
    </test>
    -->

    <!-- Module 9: Join Organisation (TODO) -->
    <!--
    <test name="Join Organisation">
        <classes>
            <class name="com.mybharat.tests.organisation.JoinOrgTest"/>
        </classes>
    </test>
    -->

</suite>
