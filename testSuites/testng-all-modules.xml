<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ALL MODULES - Runs all modules SEQUENTIALLY on the SAME browser.
  
  Flow: Registration → Logout → Login → Profile → Certificate → Basic Info → Quiz → Quiz Certificate
        → Photo Upload (already logged-in registered user)
        → Logout (Welcome circle)
        → Create Mega Event (create_mega_user_prod.xlsx)
  
  Run with:
    mvn test "-Denv=prod" "-Dbrowser=chrome" "-Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml"
-->
<suite name="MYBharat All Modules" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Public Page - Header + Organization + Footer -->
   <!-- <test name="Public Page">
        <classes>
            <class name="com.mybharat.tests.youth.PublicPageTest"/>
        </classes>
    </test>-->

    <!-- Step 2: Registration → Submit popup → Save email to Excel -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
        </classes>
    </test>

    <!-- Step 3: Logout after registration -->
    <test name="Logout After Registration">
        <classes>
            <class name="com.mybharat.tests.youth.LogoutTest"/>
        </classes>
    </test>

    <!-- Step 4: Login with email from Excel (OTP based) -->
    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

    <!-- Step 5: Complete Youth Profile -->
    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <!-- Step 6: Registration Certificate Verification -->
    <test name="Registration Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationCertificateVerificationTest"/>
        </classes>
    </test>

    <!-- Step 7: Basic Info + Extract Email -->
    <test name="Youth Basic Info">
        <classes>
            <class name="com.mybharat.tests.youth.BasicInfoTest"/>
        </classes>
    </test>

    <!-- Step 8: Quiz Attempt -->
    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

    <!-- Step 9: Quiz Certificate Download -->
    <test name="Quiz Certificate Verification">
        <classes>
            <class name="com.mybharat.tests.youth.QuizCertificateVerificationTest"/>
        </classes>
    </test>

    <!-- Step 10: Mega Event Photo Upload — with already logged-in registered user -->
    <test name="Mega Event Photo Upload">
        <classes>
            <class name="com.mybharat.tests.megaevent.MegaEventPhotoUploadTest"/>
        </classes>
    </test>

    <!-- Step 11: Logout via Welcome circle — before Mega Event user login -->
    <test name="Logout After Photo Upload">
        <classes>
            <class name="com.mybharat.tests.youth.LogoutTest"/>
        </classes>
    </test>

    <!-- Step 12: Create Mega Event — login from create_mega_user_prod.xlsx -->
    <test name="Create Mega Event">
        <classes>
            <class name="com.mybharat.tests.megaevent.MegaEventTest"/>
        </classes>
    </test>

    <!-- Module: CV Builder (TODO) -->
    <!--
    <test name="CV Builder">
        <classes>
            <class name="com.mybharat.tests.cvbuilder.CVBuilderTest"/>
        </classes>
    </test>
    -->

    <!-- Module: Organisation Creation (TODO) -->
    <!--
    <test name="Organisation Creation">
        <classes>
            <class name="com.mybharat.tests.organisation.OrgCreationTest"/>
        </classes>
    </test>
    -->

</suite>
