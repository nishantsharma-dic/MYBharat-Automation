<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ALL MODULES - Runs all modules SEQUENTIALLY on the SAME browser.
  
  Flow: Public Page → Registration → Login → Youth Profile → Quiz
  
  Run with:
    mvn test "-Denv=prod" "-Dbrowser=chrome" "-Dsurefire.suiteXmlFiles=testSuites/testng-all-modules.xml"
-->
<suite name="MYBharat All Modules" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Public Page - Header + Organization + Footer -->
    <test name="Public Page">
        <classes>
            <class name="com.mybharat.tests.youth.PublicPageTest"/>
        </classes>
    </test>

    <!-- Step 2: Registration → Submit popup → Save email to Excel → Logout -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.YouthRegistrationTest"/>
        </classes>
    </test>

    <!-- Step 3: Login with email from Excel (OTP based) -->
    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

    <!-- Step 4: Complete Youth Profile -->
    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <!-- Step 5: Quiz Attempt -->
    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
