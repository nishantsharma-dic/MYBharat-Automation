<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  ============================================================
  Public Page Suite - Header Menu + Organization + Footer Validation
  ============================================================
  Purpose: Validates all publicly accessible pages on MYBharat WITHOUT user login.
           Tests every header menu, dropdown submenu, organization section, and footer link.
  
  What it validates:
    - Top-level header menus: Youth, Quiz & Essay, MY Bharat Podcast, VVVP 2026
    - Resources dropdown: Voices, Blogs, Newsletters, Other Resources
    - Events dropdown: Experiential Learning, Volunteer for Bharat, Mega Events, VBYLD-2026
    - Organization section: Government, Knowledge Institutions, Not for Profits, For Profits
    - Footer: Important Links, Useful Links, Powered By (Digital India logo)
  
  Prerequisites:
    - No login required (public page validation)
    - Application must be accessible on the target environment
  
  Run with:
    mvn test -Denv=prod -Dbrowser=chrome -Dsurefire.suiteXmlFiles=testSuites/testng-public-page.xml
    mvn test -Denv=prod -Dbrowser=firefox -Dsurefire.suiteXmlFiles=testSuites/testng-public-page.xml
    mvn test -Denv=beta -Dbrowser=headless -DciMode=true -Dsurefire.suiteXmlFiles=testSuites/testng-public-page.xml
  
  Team: QA Team | Developer: Nishant Sharma
  ============================================================
-->
<suite name="Public Page Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <test name="Public Page - Search and Header Menu">
        <classes>
            <class name="com.mybharat.tests.youth.PublicPageTest"/>
        </classes>
    </test>

</suite>
