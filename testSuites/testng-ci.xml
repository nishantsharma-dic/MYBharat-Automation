<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  CI Suite - Designed for GitHub Actions (headless, higher latency).
  
  Only includes tests that work reliably on remote runners:
  - Registration (creates new user, saves email)
  - Logout (verifies logout works)
  
  Tests that require fast session persistence (Login → Profile → Quiz)
  are excluded as they timeout on US-based GitHub runners hitting Indian servers.
  
  Run with:
    mvn test -Denv=prod -Dbrowser=headless -Dsurefire.suiteXmlFiles=testSuites/testng-ci.xml
-->
<suite name="CI Suite — MY Bharat" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Registration → Save email to Excel -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
        </classes>
    </test>

    <!-- Logout after registration -->
    <test name="Logout After Registration">
        <classes>
            <class name="com.mybharat.tests.youth.LogoutTest"/>
        </classes>
    </test>

</suite>
