<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
  CI Suite - All modules EXCEPT Certificate Download.
  
  Certificate download is skipped on CI because headless Chrome
  cannot handle JS-generated blob downloads.
  
  Flow: Registration → Logout → Login → Profile → Basic Info → Quiz
  
  Run with:
    mvn test -Denv=prod -Dbrowser=headless -DciMode=true -Dsurefire.suiteXmlFiles=testSuites/testng-ci.xml
-->
<suite name="MYBharat CI Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="com.mybharat.listeners.TestListeners"/>
    </listeners>

    <!-- Step 1: Registration → Save email to Excel -->
    <test name="Youth Registration">
        <classes>
            <class name="com.mybharat.tests.youth.RegistrationTest"/>
        </classes>
    </test>

    <!-- Step 2: Logout after registration -->
    <test name="Logout After Registration">
        <classes>
            <class name="com.mybharat.tests.youth.LogoutTest"/>
        </classes>
    </test>

    <!-- Step 3: Login with email from Excel -->
    <test name="Youth Login">
        <classes>
            <class name="com.mybharat.tests.youth.LoginTest"/>
        </classes>
    </test>

    <!-- Step 4: Complete Youth Profile -->
    <test name="Youth Profile Completion">
        <classes>
            <class name="com.mybharat.tests.youth.YouthProfileTest"/>
        </classes>
    </test>

    <!-- Step 5: Quiz Attempt -->
    <test name="Quiz Attempt">
        <classes>
            <class name="com.mybharat.tests.youth.QuizAttemptTest"/>
        </classes>
    </test>

</suite>
